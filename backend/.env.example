# Copy to .env and set values. Never commit .env or real secrets.
# cp .env.example .env

# ----- Development (default) -----
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-this-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-base64-encoded
# DATABASE_URL=sqlite:///./database/research_data.db
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----- Production: generate keys with -----
#   python scripts/generate_production_keys.py
# Then set:
ENVIRONMENT=production
# SECRET_KEY=<output from script>
# ENCRYPTION_KEY=<output from script>
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# CORS_ORIGINS=https://your-frontend.example.com
# AUTH_COOKIE_SECURE=true

# Optional
# ACCESS_TOKEN_EXPIRE_MINUTES=30
