# Copy to .env.local (or .env) for local development. For production build, set when building.
# Create React App uses REACT_APP_* only at build time.

# API base URL (no trailing slash)
# Development (default if unset):
# REACT_APP_API_URL=http://localhost:8000

# Production: set to your API URL before npm run build
# REACT_APP_API_URL=https://api.yourdomain.com
